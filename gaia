<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Omniscribe Pro</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        /* Mobile safe framework preventing entire window bounce while allowing scrollable interior boxes */
        html, body {
            position: fixed;
            width: 100%;
            height: 100%;
            overflow: hidden;
        }
        .scrollable-content {
            overflow-y: auto;
            -webkit-overflow-scrolling: touch;
        }
    </style>
</head>
<body class="bg-slate-950 text-slate-100 h-screen flex flex-col text-xs select-none">

    <header class="bg-slate-900 p-3 flex justify-between items-center border-b border-slate-800 shrink-0 z-10">
        <h1 class="font-bold text-sm tracking-tight flex items-center gap-2">
            <span class="bg-indigo-600 text-white px-1.5 py-0.5 rounded text-xs">Ω</span>
            Omniscribe <span id="p-title" class="text-indigo-400 font-normal">| The Iron Hegemony</span>
        </h1>
        <button onclick="exportTxt()" class="bg-indigo-600 hover:bg-indigo-500 active:scale-95 px-3 py-1 rounded font-bold transition-all shadow-md shadow-indigo-950/50">
            Export Archive
        </button>
    </header>

    <main class="flex flex-1 overflow-hidden flex-col md:flex-row w-full">
        
        <nav class="bg-slate-900/60 p-1.5 flex md:flex-col gap-1 border-b md:border-b-0 md:border-r border-slate-800 shrink-0 overflow-x-auto whitespace-nowrap">
            <button onclick="tab('physics')" id="n-physics" class="px-3 py-2 rounded text-slate-200 font-semibold transition-all text-left flex items-center gap-2">
                <span>🪐</span> Physics Engine
            </button>
            <button onclick="tab('faction')" id="n-faction" class="px-3 py-2 rounded text-slate-400 font-semibold transition-all text-left flex items-center gap-2">
                <span>🛡️</span> Factions & Law
            </button>
            <button onclick="tab('names')" id="n-names" class="px-3 py-2 rounded text-slate-400 font-semibold transition-all text-left flex items-center gap-2">
                <span>📜</span> Name Matrix
            </button>
        </nav>

        <section class="flex-1 p-4 scrollable-content space-y-4 bg-slate-950">
            
            <div id="p-physics" class="space-y-4 block">
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 bg-slate-900/30 p-4 rounded-xl border border-slate-800/80">
                    <div class="space-y-1">
                        <div class="flex justify-between font-medium text-slate-400"><span>Planetary Mass</span><span id="v-mass" class="font-mono text-indigo-400 font-bold">1.00 M⊕</span></div>
                        <input type="range" id="m" min="0.1" max="5" step="0.05" value="1" oninput="calc()" class="w-full h-1 bg-slate-800 rounded appearance-none cursor-pointer accent-indigo-500">
                    </div>
                    <div class="space-y-1">
                        <div class="flex justify-between font-medium text-slate-400"><span>Planetary Radius</span><span id="v-rad" class="font-mono text-indigo-400 font-bold">1.00 R⊕</span></div>
                        <input type="range" id="r" min="0.5" max="3" step="0.05" value="1" oninput="calc()" class="w-full h-1 bg-slate-800 rounded appearance-none cursor-pointer accent-indigo-500">
                    </div>
                    <div class="space-y-1">
                        <div class="flex justify-between font-medium text-slate-400"><span>Atmospheric Pressure</span><span id="v-den" class="font-mono text-emerald-400 font-bold">1.0 atm</span></div>
                        <input type="range" id="d" min="0.1" max="10" step="0.1" value="1" oninput="calc()" class="w-full h-1 bg-slate-800 rounded appearance-none cursor-pointer accent-emerald-500">
                    </div>
                    <div class="space-y-1">
                        <div class="flex justify-between font-medium text-slate-400"><span>Greenhouse Forcing</span><span id="v-gh" class="font-mono text-emerald-400 font-bold">1.0x</span></div>
                        <input type="range" id="g" min="0" max="5" step="0.1" value="1" oninput="calc()" class="w-full h-1 bg-slate-800 rounded appearance-none cursor-pointer accent-emerald-500">
                    </div>
                </div>
                <div class="grid grid-cols-2 gap-3 font-mono">
                    <div class="bg-slate-900/60 border border-slate-800 p-3 rounded-lg">Surface Gravity: <span id="d-grav" class="text-indigo-400 font-bold">1.00g</span></div>
                    <div><div class="bg-slate-900/60 border border-slate-800 p-3 rounded-lg">Calculated Temperature: <span id="d-temp" class="text-emerald-400 font-bold">15.0°C</span></div></div>
                </div>
            </div>

            <div id="p-faction" class="space-y-4 hidden">
                <div class="space-y-3 bg-slate-900/20 border border-slate-800/80 p-4 rounded-xl">
                    <div>
                        <label class="block text-[10px] uppercase font-bold text-slate-500 tracking-wider mb-1">Faction System Name</label>
                        <input type="text" id="f-name" value="The Iron Hegemony" oninput="uFac()" class="w-full bg-slate-900 border border-slate-800 rounded p-2.5 font-medium focus:outline-none focus:border-indigo-500 text-slate-200 select-text">
                    </div>
                    <div>
                        <label class="block text-[10px] uppercase font-bold text-slate-500 tracking-wider mb-1">Administrative Matrix Archetype</label>
                        <select id="f-type" onchange="facTpl()" class="w-full bg-slate-900 border border-slate-800 rounded p-2.5 focus:outline-none focus:border-indigo-500 font-medium text-slate-300">
                            <option value="feudal">Decentralized Feudal Framework</option>
                            <option value="hydraulic">Centralized Hydraulic Empire</option>
                            <option value="magocracy">High Fantasy Magocracy</option>
                        </select>
                    </div>
                    <div class="p-3 bg-indigo-950/30 border border-indigo-900/40 rounded-lg text-slate-300 italic font-serif leading-relaxed" id="f-prompt"></div>
                    <div>
                        <label class="block text-[10px] uppercase font-bold text-slate-500 tracking-wider mb-1">Field Dossier Journal Entries</label>
                        <textarea id="f-notes" rows="6" oninput="uFac()" class="w-full bg-slate-900 border border-slate-800 rounded p-3 font-serif text-slate-300 focus:outline-none focus:border-indigo-500 text-xs leading-relaxed select-text" placeholder="Flesh out historical milestones, environmental adaptations, and systemic legal frameworks..."></textarea>
                    </div>
                </div>
            </div>

            <div id="p-names" class="space-y-4 hidden">
                <div class="flex gap-2 bg-slate-900/40 p-3 rounded-xl border border-slate-800/80">
                    <select id="n-cult" class="flex-1 bg-slate-900 border border-slate-800 rounded p-2 focus:outline-none text-slate-300 font-medium">
                        <option value="norse">Old Norse Archetype</option>
                        <option value="roman">Imperial Roman Formula</option>
                        <option value="nahuatl">Aztec Nahuatl Compound</option>
                        <option value="anglosaxon">Anglo-Saxon Dithematic</option>
                    </select>
                    <button onclick="genNames()" class="bg-emerald-600 hover:bg-emerald-500 active:scale-95 text-white font-bold px-4 rounded transition-all shadow-md shadow-emerald-950/40">Synthesize</button>
                </div>
                <ul id="n-list" class="grid grid-cols-2 gap-2 font-mono text-emerald-400 bg-slate-900/20 p-3 rounded-xl border border-slate-800">
                    <li class="col-span-2 text-slate-600 italic text-center py-2">Awaiting vocabulary processing syntax generation...</li>
                </ul>
            </div>
        </section>

        <section class="w-full md:w-64 bg-slate-900/30 border-t md:border-t-0 md:border-l border-slate-800/80 p-4 flex flex-col items-center justify-between gap-4 shrink-0 bg-slate-900/10">
            <div class="flex justify-between items-center w-full bg-slate-950 p-2 rounded-lg border border-slate-800/40">
                <span class="font-bold text-slate-400 tracking-wide">Visual Feedback</span>
                <button id="v-toggle" onclick="toggleV()" class="bg-indigo-600 hover:bg-indigo-500 active:scale-95 px-2.5 py-1 rounded text-[10px] font-black tracking-wider transition-all">3D Globe</button>
            </div>
            
            <div class="relative flex items-center justify-center py-2">
                <div id="canvas" class="w-32 h-32 sm:w-40 sm:h-40 rounded-xl transition-all duration-700 ease-out shadow-2xl border border-slate-800/60" style="background: radial-gradient(circle, #22c55e 0%, #15803d 70%);"></div>
                <div id="shadow-overlay" class="absolute inset-0 rounded-xl pointer-events-none transition-all duration-700 bg-gradient-to-tr from-slate-950/40 via-transparent to-transparent"></div>
            </div>
            
            <div class="w-full bg-slate-950 border border-slate-800 p-3 rounded-xl font-mono text-[11px] shadow-inner space-y-0.5">
                <div class="text-indigo-400 font-bold" id="b-name">Temperate Forest</div>
                <div class="text-slate-400 text-[10px]" id="b-moist">Stable Water Retention</div>
            </div>
        </section>
    </main>

    <script>
        const state = { id: "w_"+Math.floor(Math.random()*99999), name: "The Iron Hegemony", type: "feudal", notes: "", vMode: "2d", g: 1, t: 15, d: 1, gh: 1 };
        
        const matrices = {
            norse: { pre: ["Thor", "Sig", "Bjorn", "Ragnar", "Ivar", "Hrafn", "Gunn"], suf: ["stein", "mund", "kell", "geir", "vald", "run", "thor"], t: ["the Defiant", "Sunder-Shield", "Sea-Gazer", "Oathtaker"] },
            roman: { pre: ["Gaius", "Marcus", "Lucius", "Publius", "Tiberius", "Aulus"], suf: ["Julius", "Cornelius", "Claudius", "Fabius", "Valerius", "Tullius"], t: ["Magnus", "Africanus", "Severus", "Cicero"] },
            nahuatl: { pre: ["Moctez", "Quetzal", "Ahuitz", "Itz", "Cuaht", "Xochi"], suf: ["uma", "coatl", "otl", "emoc", "pilli", "matl"], t: ["Tlatoani", "The Eagle Essence", "Obsidian Heart"] },
            anglosaxon: { pre: ["Aethel", "Cyn", "Ead", "Wulf", "Osw", "Frith"], suf: ["stan", "ward", "ric", "wine", "gar", "thryth"], t: ["of Wessex", "Iron-Arm", "Barrow-Warden", "Wynn"] }
        };

        const prompts = {
            feudal: "SYSTEMIC RULES: Central crown authority is physically restricted. Who leads local frontier garrisons, and how is local economic energy extracted without stable liquid mint currency loops?",
            hydraulic: "SYSTEMIC RULES: Settled communities are locked to dynamic major water channels. Your state controls the lock gates. Who maintains systemic distribution profiles during critical historical drought regimes?",
            magocracy: "SYSTEMIC RULES: Arcane field concentrations bypass baseline physical thermodynamics. Since casting elites manifest localized kinetics freely, how are standard timber/stone defensive wall frameworks engineered?"
        };

        function tab(id) {
            ["physics", "faction", "names"].forEach(k => {
                document.getElementById(`p-${k}`).style.display = k === id ? "block" : "none";
                document.getElementById(`n-${k}`).className = `px-3 py-2 rounded font-semibold text-xs text-left flex items-center gap-2 transition-all ${k===id ? 'bg-slate-850 text-white shadow-sm border border-slate-800' : 'text-slate-400 hover:text-slate-200'}`;
            });
        }

        function toggleV() {
            state.vMode = state.vMode === "2d" ? "3d" : "2d";
            const is3d = state.vMode === "3d";
            document.getElementById("v-toggle").innerText = is3d ? "2D Flat" : "3D Globe";
            document.getElementById("canvas").className = `w-32 h-32 sm:w-40 sm:h-40 shadow-2xl border border-slate-800/60 transition-all duration-700 ease-out ${is3d ? 'rounded-full animate-[spin_40s_linear_infinite]' : 'rounded-xl'}`;
            document.getElementById("shadow-overlay").className = `absolute inset-0 pointer-events-none transition-all duration-700 ${is3d ? 'rounded-full bg-[radial-gradient(circle_at_top_left,rgba(255,255,255,0.08)_0%,rgba(0,0,0,0.65)_85%)]' : 'rounded-xl bg-gradient-to-tr from-slate-950/40 via-transparent to-transparent'}`;
        }

        function calc() {
            const m = parseFloat(document.getElementById("m").value), r = parseFloat(document.getElementById("r").value);
            state.d = parseFloat(document.getElementById("d").value); state.gh = parseFloat(document.getElementById("g").value);
            
            document.getElementById("v-mass").innerText = m.toFixed(2)+" M⊕"; document.getElementById("v-rad").innerText = r.toFixed(2)+" R⊕";
            document.getElementById("v-den").innerText = state.d.toFixed(1)+" atm"; document.getElementById("v-gh").innerText = state.gh.toFixed(1)+"x";

            state.g = m / Math.pow(r, 2);
            // Enhanced curve formula balancing expansion properties at thermodynamic boundaries
            state.t = 15 + (state.d * 8.2) + (state.gh * 11.8) - (r * 4.5);
            
            document.getElementById("d-grav").innerText = state.g.toFixed(2)+"g";
            document.getElementById("d-temp").innerText = state.t.toFixed(1)+"°C";
            renderView();
        }

        function renderView() {
            const v = document.getElementById("canvas"), n = document.getElementById("b-name"), m = document.getElementById("b-moist");
            if (state.t < 0) {
                v.style.background = "radial-gradient(circle, #f1f5f9 0%, #475569 85%)"; n.innerText = "Glacial Polar Tundra"; m.innerText = "Locked Permafrost / Frost Cryosphere";
            } else if (state.t < 18) {
                v.style.background = state.d < 1.6 ? "radial-gradient(circle, #4ade80 0%, #166534 85%)" : "radial-gradient(circle, #0d9488 0%, #115e59 85%)";
                n.innerText = state.d < 1.6 ? "Temperate Woodlands" : "Saturated Boreal Taiga"; m.innerText = "Continuous Equilibrium Rainfall";
            } else {
                v.style.background = state.d < 1.8 ? "radial-gradient(circle, #fef08a 0%, #854d0e 85%)" : "radial-gradient(circle, #22c55e 0%, #14532d 85%)";
                n.innerText = state.d < 1.8 ? "Hyper-Arid Desert Core" : "Torrential Jungle Canopy"; m.innerText = state.d < 1.8 ? "High Evaporative Water Deficit" : "Saturated Dense Moisture Loop";
            }
        }

        function facTpl() {
            state.type = document.getElementById("f-type").value;
            document.getElementById("f-prompt").innerText = prompts[state.type];
            uFac();
        }

        function uFac() {
            state.name = document.getElementById("f-name").value;
            state.notes = document.getElementById("f-notes").value;
            document.getElementById("p-title").innerText = "| " + (state.name || "Untitled Project");
        }

        function genNames() {
            const k = document.getElementById("n-cult").value, mat = matrices[k], list = document.getElementById("n-list");
            list.innerHTML = "";
            for(let i=0; i<6; i++) {
                const p = mat.pre[Math.floor(Math.random()*mat.pre.length)], s = mat.suf[Math.floor(Math.random()*mat.suf.length)], t = mat.t[Math.floor(Math.random()*mat.t.length)];
                const li = document.createElement("li");
                li.className = "bg-slate-950 p-2 rounded text-center border border-slate-900 font-semibold shadow-sm text-[10px]";
                li.innerText = k === "roman" ? `${p} ${s} ${t}` : `${p}${s} ${t}`;
                list.appendChild(li);
            }
        }

        function exportTxt() {
            uFac();
            const archive = {
                header: { application: "Omniscribe Pro", version: "2026.1.0", generated: new Date().toISOString() },
                metrics: { uniqueId: state.id, surfaceGravityG: state.g, equilibriumTempC: state.t, columnAtm: state.d }
            };
            const stream = `---\nOMNISCRIBE_SYSTEM_METADATA\n${JSON.stringify(archive, null, 2)}\n---\n# PROJECT LORE ARCHIVE: ${state.name.toUpperCase()}\n* Structural Framework System: ${state.type.toUpperCase()}\n\n## FIELD NOTES\n${state.notes || 'No notes currently recorded in local memory storage workspace.'}`;
            const blob = new Blob([stream], { type: "text/plain;charset=utf-8" });
            const a = document.createElement("a"); a.href = URL.createObjectURL(blob);
            a.download = `${(state.name || 'unnamed').toLowerCase().replace(/\s+/g, '_')}_backup.txt`;
            document.body.appendChild(a); a.click(); document.body.removeChild(a);
        }

        // Window entry point hooks
        window.onload = () => { calc(); facTpl(); tab('physics'); };
    </script>
</body>
</html>
