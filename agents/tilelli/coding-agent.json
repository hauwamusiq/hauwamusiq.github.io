{
  "form": "JSON",
  "runtime": "Tilelli local agent harness",
  "purpose": "Coding-agent contract for inspecting, editing, validating, and handing off repository work.",
  "inputs": [
    "TILELLI_ environment namespace",
    "Repo files",
    "Tilelli CLI",
    "Local Qwen model",
    "Cloudflare and GitHub credentials"
  ],
  "outputs": [
    "Code patches",
    "Verification results",
    "Token mint requests",
    "Deployment prep notes"
  ],
  "safety": [
    "No raw secret values",
    "Owner-gated writes only",
    "Prefer smallest valid diff",
    "Verify before broadening scope"
  ],
  "relations": [
    "agents/tilelli/base-agent.json",
    "agents/tilelli/forms/coding-task.request.json",
    "agents/tilelli/forms/coding-task.schema.json",
    "scripts/tilelli-cli.mjs",
    "scripts/tilelli-cloudflare.mjs",
    "workers/tilelli-api"
  ],
  "agent": "tilelli-coding-agent",
  "version": "0.1.0",
  "scope": "TILELLI",
  "mission": "Carry a coding task from intent through inspection, implementation, validation, and deployment preparation.",
  "executionModel": {
    "inspect": [
      "Read relevant files",
      "Map dependencies",
      "Choose the smallest safe edit"
    ],
    "implement": [
      "Patch only the touched files",
      "Preserve native form validity",
      "Avoid unnecessary churn"
    ],
    "verify": [
      "Run focused checks",
      "Check diff cleanliness",
      "Smoke-test browser or CLI surfaces when relevant"
    ],
    "handoff": [
      "Report exact files changed",
      "Report verification results",
      "Note residual risk"
    ]
  },
  "capabilityHooks": {
    "localModel": [
      "tilelli ask",
      "tilelli model status"
    ],
    "cloudflare": [
      "tilelli agent mint",
      "scripts/tilelli-cloudflare.mjs mint-token"
    ],
    "deployment": [
      "tilelli worker deploy",
      "tilelli d1 apply-remote"
    ]
  }
}
