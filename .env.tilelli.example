# Tilelli project-of-projects environment namespace.
# Do not commit real secret values.

TILELLI_PROJECT_OWNER_EMAIL=hauwamusiq@gmail.com
TILELLI_GITHUB_USER=hauwamusiq
TILELLI_PROJECT_ROOT=/Users/johnmobley/tilelli

TILELLI_CLOUDFLARE_EMAIL=hauwamusiq@gmail.com
TILELLI_CLOUDFLARE_ACCOUNT_ID=

# Bootstrap only. Prefer minting a scoped token and then retiring this from automation.
TILELLI_CLOUDFLARE_GLOBAL_API_KEY=

# Preferred for Wrangler/GitHub Actions deployment.
TILELLI_CLOUDFLARE_API_TOKEN=

# Worker write gate. Set as a Cloudflare Worker secret, not in client-side HTML.
TILELLI_OWNER_WRITE_KEY=

# Anime generation handoff. Shared by the API Worker and renderer Worker.
TILELLI_GENERATION_CALLBACK_KEY=
TILELLI_GENERATION_RENDERER_URL=
